# Copie este arquivo para .env e preencha com seus dados reais

# ── APLIS ──────────────────────────────────────────────────────
APLIS_BASE_URL=https://seu-laboratorio.aplis.inf.br
APLIS_USER=seu_usuario_aplis
APLIS_PASS=sua_senha_aplis
APLIS_ID_LABORATORIO=1
# Tipo da imagem: 1=Imagem do pedido, 5=Documento
APLIS_TIPO_IMAGEM_GUIA=1

# ── AUTENTIQUE ─────────────────────────────────────────────────
AUTENTIQUE_TOKEN=seu_token_autentique_aqui
# Token secreto configurado no painel Autentique → Webhooks
AUTENTIQUE_WEBHOOK_SECRET=

# ── SERVIDOR ───────────────────────────────────────────────────
WS_HOST=0.0.0.0
WS_PORT=8000

# ── STORAGE ────────────────────────────────────────────────────
PASTA_GUIAS_ASSINADAS=C:\guias_assinadas

# ── TESTE ──────────────────────────────────────────────────────
# UUID do documento Autentique para o teste de fluxo completo
AUTENTIQUE_UUID_TESTE=
# Caminho para PDF real de teste (opcional)
PDF_TESTE_PATH=
